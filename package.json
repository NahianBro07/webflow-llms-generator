{
  "name": "webflow-llms-generator",
  "version": "1.0.0",
  "description": "Generate optimized llms.txt files for Webflow websites for LLM consumption",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "generate": "node dist/cli.js",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "webflow",
    "llm",
    "ai",
    "llms.txt",
    "crawler",
    "sitemap"
  ],
  "author": "NahianBro07",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "zod": "^3.22.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
